generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Link {
  id                 String   @id
  originalUrl        String   @unique
  previewTitle       String
  previewDescription String
  previewImage       String?
  createdAt          DateTime @default(now())
}
